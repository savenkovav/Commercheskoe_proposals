# Настройки Meilisearch (скопируйте нужные ключи в корневой .env проекта)

MEILISEARCH_ENABLED=false
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_API_KEY=masterKey
MEILISEARCH_INDEX=products
# Переиндексация при reload каталога/реестра/прайсов
MEILISEARCH_AUTO_SYNC=true
# Сколько кандидатов забирать из индекса на один источник
MEILISEARCH_SEARCH_LIMIT=20
