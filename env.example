# Веб-интерфейс
WEB_HOST=127.0.0.1
WEB_PORT=8080
# true — за nginx/прокси (Beget VPS, docker-compose.prod.yml)
WEB_BEHIND_PROXY=false
# Публичный URL для продакшена (необязательно)
# PUBLIC_BASE_URL=https://probizness.ru

# ProxyAPI (шлюз, совместимый с OpenAI)
PROXYAPI_API_KEY=your_proxyapi_key
PROXYAPI_BASE_URL=https://api.proxyapi.ru/openai/v1
OPENAI_MODEL=gpt-4o-mini

# Настройки компании
MARKUP_PERCENT=30
COMPANY_NAME=ООО «Учтендер»
COMPANY_INN=4727015060
COMPANY_KPP=472701001
COMPANY_OGRN=125470001348
COMPANY_ADDRESS=Ленинградская область, м.р-н Тихвинский, г.п. Тихвинское, г. Тихвин, ул Карла Маркса, д. 86д
DELIVERY_TERMS=адресная доставка включена в стоимость
PAYMENT_TERMS=безналичный расчет
DELIVERY_DAYS=15 рабочих дней после получения денежных средств

# Пути к данным (относительно корня проекта)
CATALOG_PATH=data/catalog.xlsx
# Товарный отчёт (поставщик, дата покупки): Наименование, Поставщик, Дата покупки, Себест., Цена
GOODS_REPORT_PATH=data/goods_report.xlsx
# Отчёт по закупкам (1С): позиция + строка поставщика под ней
# Для составляющих комплектов: поставщик и дата покупки — только при совпадении с каталогом
PROCUREMENT_REPORT_PATH=../../Проект КП/Образцы/Отчет по закупкам.xlsx
USE_GOODS_REPORT=true
REGISTRY_PATH=data/registry.xlsx
REGISTRY_PHOTOS_DIR=data/registry_photos
PRICE_LISTS=data/price_prirodovedenie.xls

# Пороги совпадения (0-100)
EXACT_MATCH_THRESHOLD=90
SIMILAR_MATCH_THRESHOLD=70
# Минимум совпадения в каталоге/прайсе (95%); ниже — интернет-поиск (100%)
LOCAL_MATCH_THRESHOLD=95

# Хранение прайс-листов
PRICES_DIR=data/prices
PRICES_REGISTRY_PATH=data/prices_registry.json
SOURCES_REGISTRY_PATH=data/sources_registry.json

# AI-поиск цен в интернете при формировании КП
# true — AI-цены конкурентов для всех позиций (~1 запрос на позицию, медленно)
# false — поисковые ссылки сразу; AI-цена только если позиция не найдена в каталогах/прайсах
USE_AI_INTERNET_SEARCH=false

# Веб-поиск по поисковой выдаче (DuckDuckGo) при отсутствии совпадения в каталогах/прайсах
# Берутся только страницы со 100% совпадением названия позиции (порог ниже)
WEB_SEARCH_ENABLED=true
# Минимум совпадения названия из интернета для загрузки в таблицу (0–100)
WEB_SEARCH_EXACT_THRESHOLD=100
WEB_SEARCH_MAX_RESULTS=3
# Загружать страницы товаров для извлечения цены (если в сниппете нет цены)
WEB_SEARCH_FETCH_PAGES=true
# Макс. загрузок страниц на одну позицию (ускоряет обработку)
WEB_SEARCH_MAX_PAGE_FETCHES=2
WEB_SEARCH_TIMEOUT=8
# Лимит символов HTML: карточка товара / страница поиска (у крупных каталогов выдача далеко внизу)
WEB_SEARCH_PAGE_MAX_CHARS=200000
WEB_SEARCH_RESULTS_PAGE_MAX_CHARS=700000
# Для позиций из интернета: скидка от найденной цены вместо наценки
WEB_PRICE_DISCOUNT_PERCENT=5

# Поиск на сайтах конкурентов (приоритетнее маркетплейсов)
COMPETITOR_SEARCH_ENABLED=true
# Меньше доменов в одном запросе DuckDuckGo — больше батчей и лучше охват
COMPETITOR_SEARCH_BATCH_SIZE=3
# Макс. результатов с сайтов конкурентов на одну позицию (для выбора мин. цены)
COMPETITOR_SEARCH_MAX_RESULTS=5
# Если нет совпадения 100% на конкурентах — ослабить порог до 95%
COMPETITOR_SEARCH_FALLBACK_THRESHOLD=95
# Поиск через встроенный поиск сайтов конкурентов (?q=, search?text= и т.п.)
COMPETITOR_NATIVE_SEARCH_ENABLED=true
# Лимит HTTP-запросов к сайтам конкурентов на одну позицию
COMPETITOR_NATIVE_SEARCH_MAX_FETCHES=8

# Meilisearch — быстрый полнотекстовый поиск по каталогу/реестру/прайсам
MEILISEARCH_ENABLED=false
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_API_KEY=masterKey
MEILISEARCH_INDEX=products
MEILISEARCH_AUTO_SYNC=true
MEILISEARCH_SEARCH_LIMIT=20

# Параллельная обработка позиций ТЗ (ускоряет большие ТЗ)
KP_PARALLEL_WORKERS=4

# Поиск ссылок конкурентов для составляющих комплекта (медленно при большом составе)
SEARCH_KIT_COMPONENT_LINKS=false

# Парсинг ТЗ: PDF OCR (нужен Tesseract: brew install tesseract tesseract-lang)
TZ_PDF_OCR_ENABLED=true
TZ_OCR_LANG=rus+eng
# TESSERACT_CMD=/usr/local/bin/tesseract

# Защита ПДн перед отправкой данных в OpenAI
PII_ANONYMIZATION_ENABLED=true
PII_REDACT_ORG_DATA=true
# Дополнительные термины для маскировки, через | (необязательно)
PII_EXTRA_TERMS=
