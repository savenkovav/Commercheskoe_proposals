# Локальные параметры деплоя (скопируйте в deploy/vps.deploy.env)
# Используется scripts/deploy_vps_key.ps1 и scripts/deploy_vps_key.sh

VPS_HOST=77.222.55.100
VPS_USER=root
VPS_PORT=22
VPS_APP_DIR=/opt/comm-proposals

# Путь к приватному SSH-ключу (Windows или WSL)
VPS_SSH_KEY=C:\Projects\Comm_proposals\id_rsa\id_rsa

# Публичный URL приложения (домен или http://IP)
PUBLIC_BASE_URL=http://77.222.55.100

# standalone — встроенный nginx в Docker (порт 80)
# proxy — внешний nginx на хосте (сеть root_target_network)
DEPLOY_MODE=standalone

# Дополнительно открыть порт 8080 для прямого доступа к приложению
EXPOSE_APP_PORT=true
